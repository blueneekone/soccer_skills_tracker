{
  "firestore": [
    {
      "database": "(default)",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'unsafe-inline' https://unpkg.com https://static.cloudflareinsights.com https://maps.googleapis.com https://maps.gstatic.com https://*.gstatic.com https://apis.google.com https://accounts.google.com https://web-sdk-services.checkr.com https://web-sdk-services.checkr-staging.com; style-src 'self' 'unsafe-inline' https://unpkg.com https://fonts.googleapis.com https://accounts.google.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com https://unpkg.com; worker-src 'self' blob:; connect-src 'self' https://*.firebaseio.com wss://*.firebaseio.com https://*.googleapis.com https://sstracker.app https://soccer.sstracker.app https://cloudflareinsights.com https://static.cloudflareinsights.com https://*.cloudfunctions.net https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://accounts.google.com https://*.firebaseapp.com https://api.checkr.com https://api.checkr-staging.com https://web-sdk-services.checkr.com https://web-sdk-services.checkr-staging.com; frame-src 'self' https://accounts.google.com https://www.gstatic.com https://*.google.com https://*.firebaseapp.com https://web-sdk-services.checkr.com https://web-sdk-services.checkr-staging.com; frame-ancestors 'none'; upgrade-insecure-requests"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=63072000; includeSubDomains; preload"
          }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/v1/**",
        "function": {
          "functionId": "apiGateway",
          "region": "us-east1"
        }
      },
      {
        "source": "/api/webhooks/stripe/tickets",
        "function": {
          "functionId": "handleTicketingWebhook",
          "region": "us-east1"
        }
      },
      {
        "source": "/api/webhooks/stripe/registration",
        "function": {
          "functionId": "handleRegistrationWebhook",
          "region": "us-east1"
        }
      },
      {
        "source": "/api/webhooks/stripe/recruiter",
        "function": {
          "functionId": "handleRecruiterWebhook",
          "region": "us-east1"
        }
      },
      {
        "source": "/api/compliance/checkr/session-tokens",
        "function": {
          "functionId": "checkrSessionTokens",
          "region": "us-east1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions-core",
      "codebase": "core",
      "predeploy": [
        "node scripts/bundle-functions.cjs"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "*.local"
      ]
    },
    {
      "source": "functions-rl",
      "codebase": "rl",
      "predeploy": [
        "node scripts/bundle-functions.cjs"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "*.local"
      ]
    },
    {
      "source": "functions-commerce",
      "codebase": "commerce",
      "predeploy": [
        "node scripts/bundle-functions.cjs"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "*.local"
      ]
    },
    {
      "source": "functions-compliance",
      "codebase": "compliance",
      "predeploy": [
        "node scripts/bundle-functions.cjs"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "*.local"
      ]
    },
    {
      "source": "functions-integrations",
      "codebase": "integrations",
      "predeploy": [
        "node scripts/bundle-functions.cjs"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "*.local"
      ]
    },
    {
      "source": "functions-platform",
      "codebase": "platform",
      "predeploy": [
        "node scripts/bundle-functions.cjs"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "*.local"
      ]
    }
  ],
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": false
    }
  }
}
