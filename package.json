{
  "name": "soccer-skills-tracker",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "generate:cosmetics": "node scripts/generate-cosmetics-manifest.mjs",
    "generate:portraits": "node scripts/generate-portrait-manifest.mjs",
    "check:file-budget": "node scripts/check-file-budget.mjs",
    "prebuild": "node scripts/check-no-phosphor.mjs && node scripts/check-file-budget.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./jsconfig.json --threshold error",
    "test": "vitest run",
    "test:firestore-rules": "npx firebase-tools@latest emulators:exec --only firestore --project sst-sprint-13-rules \"vitest run src/lib/security/__tests__/firestoreTenantIsolation.test.ts src/lib/security/__tests__/loopIntegrityGuards.test.ts src/lib/security/__tests__/firestoreRulesSprint412.test.ts\"",
    "deploy:comms": "firebase deploy --only \"functions:safeSportBroadcast,functions:clubSportBroadcast,functions:reportMessageIncident,functions:sendCoachPlayerMessage,functions:sendChannelMessage,functions:sendHouseholdMessage,functions:onTeamBroadcastCreated,functions:onDeploymentCalendarEntryCreated,functions:sendScheduledEventReminders,functions:sendRegistrationPaymentReminders,functions:coachProvisionParentLounge,functions:registerDeviceToken\"",
    "deploy:comms-triggers": "firebase deploy --only \"functions:onTeamBroadcastCreated,functions:onDeploymentCalendarEntryCreated\"",
    "test:watch": "vitest",
