{
  "name": "soccer-skills-tracker",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "node scripts/check-no-phosphor.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint:functions": "npm --prefix functions run lint",
    "deploy:functions": "npm run lint:functions && firebase deploy --only functions",
    "deploy": "npm run lint:functions && firebase deploy"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
