    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^4.1.6",
    "@playwright/test": "^1.52.0"
  },
  "dependencies": {
    "@dicebear/core": "^9.4.2",
