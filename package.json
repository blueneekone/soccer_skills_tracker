    "deploy:backend:systematic": "node scripts/deploy-backend-systematic.cjs",
    "deploy:dev:verify": "node scripts/deploy-dev-verify.cjs",
    "deploy:dev": "node scripts/deploy-dev-full.cjs",
    "smoke:dev": "node scripts/smoke-dev-callables.mjs",
    "deploy:dev:smoke": "node scripts/deploy-dev-and-smoke.cjs",
    "deploy:commerce": "firebase deploy --only \"functions:commerce:createRegistrationIntent,functions:commerce:handleRegistrationWebhook,functions:commerce:createConnectOnboarding,functions:commerce:getRegistrationStatus,functions:commerce:createTicketSaleIntent,functions:commerce:handleTicketingWebhook,functions:commerce:upsertTournamentEvent,functions:commerce:publishTournamentEvent,functions:commerce:verifyScanToken,functions:commerce:sendTicketReceiptOnCreate,functions:commerce:stripeWebhook,functions:commerce:createStripeCheckoutSession,functions:commerce:createSubscription,functions:commerce:sunsetLegacySubscription,functions:commerce:sweepLegacySubscriptions,functions:commerce:submitHotelRebateRecord,functions:commerce:approveHotelRebatePayout,functions:commerce:provisionHotelPartner,functions:commerce:rotateHotelPartnerKeys,functions:commerce:setHotelPartnerStatus,functions:commerce:recordRecruiterExport,functions:commerce:cancelRecruiterAccount,functions:commerce:bootstrapPricingPolicy,functions:commerce:updatePricingPolicy\"",
    "deploy:compliance": "firebase deploy --only \"functions:compliance:vaultSealPii,functions:compliance:vaultUnsealPii,functions:compliance:shredSensitiveData,functions:compliance:sendParentalConsentEmail,functions:compliance:verifyParentalConsent,functions:compliance:generateWebAuthnChallenge,functions:compliance:verifyBiometricConsent,functions:compliance:directorOutOfBandClearance,functions:compliance:generateConsentAttestationChallenge,functions:compliance:attestParentalConsent,functions:compliance:webauthnRegisterStart,functions:compliance:webauthnRegisterFinish,functions:compliance:webauthnLoginStart,functions:compliance:webauthnLoginFinish,functions:compliance:generateCheckrEmbedToken,functions:compliance:checkrSessionTokens,functions:compliance:backgroundCheckCallback,functions:compliance:checkrWebhook,functions:compliance:getComplianceRoster,functions:compliance:requestManualOverride,functions:compliance:revokeCoachClearance,functions:compliance:initiateAnkoredUplink,functions:compliance:simulateClearance,functions:compliance:directorInitiateCoachClearance,functions:compliance:verifyDocument,functions:compliance:processPendingDocDeletions,functions:compliance:getRetentionReport,functions:compliance:enqueueMinorRetentionPurge,functions:compliance:processMinorRetentionQueue,functions:compliance:purgeExpiredMinorData,functions:compliance:linkHousehold,functions:compliance:parentGrantVpcConsent,functions:compliance:parentSignCoppaWaiver,functions:compliance:parentProvisionOperative,functions:compliance:operativeSignInWithDispatch,functions:compliance:generatePlayerOTP,functions:compliance:validatePlayerOTP\"",
    "deploy:integrations": "firebase deploy --only \"functions:integrations:processMedia,functions:integrations:ingestRoster,functions:integrations:getSoccerNews,functions:integrations:searchPodcasts,functions:integrations:getPodcastEpisodes,functions:integrations:getWeatherConditions,functions:integrations:evaluateFieldWeatherLock,functions:integrations:refreshClubWeatherLock,functions:integrations:getUploadToken,functions:integrations:deleteAllPlayerMedia,functions:integrations:facilityWeatherWebhook\"",
    "deploy:platform": "firebase deploy --only \"functions:platform:apiGateway,functions:platform:bootstrapCellRegistry,functions:platform:registerDedicatedCell,functions:platform:activateCell,functions:platform:provisionTenantCell,functions:platform:peekTenantCell,functions:platform:startTenantMigration,functions:platform:markExportComplete,functions:platform:markImportComplete,functions:platform:verifyTenantOnCell,functions:platform:executeCutover,functions:platform:rollbackTenantMigration,functions:platform:flagTenantForPromotion,functions:platform:acknowledgePromotionFlag,functions:platform:evaluateCellPromotions,functions:platform:purgeGatewayCaches,functions:platform:seedSyntheticTenant,functions:platform:purgeSyntheticTenant,functions:platform:syncUserClaims,functions:platform:listTeamsForClub,functions:platform:logSecurityAudit,functions:platform:generateLicense,functions:platform:directorSaveClubBranding,functions:platform:directorInviteCoach,functions:platform:claimCoachInvite,functions:platform:secureAllocateTeamSeats,functions:platform:secureAddPlayer,functions:platform:secureRemovePlayer,functions:platform:secureUpdateJersey,functions:platform:directorUpsertField,functions:platform:secureBookField,functions:platform:onAnalyticsUserWritten,functions:platform:onAnalyticsClubWritten,functions:platform:onAnalyticsLicenseWritten,functions:platform:assignTenantClaims,functions:platform:impersonateUserFn,functions:platform:purgeUserDataFn\"",
