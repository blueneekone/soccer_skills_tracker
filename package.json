    "@stripe/stripe-js": "^9.4.0",
    "@types/papaparse": "^5.5.2",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "fabric": "^7.2.0",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^4.9.0",
    "html5-qrcode": "^2.3.8",
    "libphonenumber-js": "^1.13.1",
    "lucide-svelte": "^1.0.1",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.6.205",
    "qrcode": "^1.5.4",
    "sweetalert2": "^11.26.24",
    "xlsx": "npm:@e965/xlsx@^0.20.3"
  }
