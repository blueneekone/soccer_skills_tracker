# Set to "true" to use production Firebase (soccer-skills-tracker). Default is dev.
VITE_USE_PROD=false

# Cloud Functions (deploy): create a strong random secret, then:
#   firebase functions:secrets:set WORKOUT_ATTESTATION_HMAC_SECRET
# Required for submitWorkoutRep (HMAC integrity digest on workout logs).
#
#   firebase functions:secrets:set AFFINITY_WEBHOOK_HMAC_SECRET
# Required for affinityWebhook: raw body HMAC-SHA256, header
#   X-SSTRACKER-Signature: sha256=<hex>
#
# Epic 9 — Stripe (Cloud Functions):
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
# Configure Price IDs (per environment / project), e.g.:
#   firebase functions:config:set stripe.price_tutor="price_..."   # legacy; prefer:
# Use Firebase params in deployment UI or:
#   firebase deploy --only functions -e STRIPE_PRICE_TUTOR=price_xxx ...
# Params: STRIPE_PRICE_TUTOR, STRIPE_PRICE_TEAM, STRIPE_PRICE_CLUB, STRIPE_PRICE_RECRUITER
#
# Epic 13 — FCM web push (client): Firebase Console → Project settings → Cloud Messaging
# → Web Push certificates → Key pair → paste the *public* key here:
#   VITE_FCM_VAPID_KEY=BNxxx...

# Epic 17 Phase 2 — Field Ops logistics (Google Maps JS): Google Cloud Console → APIs & Services
# → enable Maps JavaScript API → Credentials → API key (HTTP referrer restrict to your domains).
# Drawing manager + Places (Facility Vault satellite markup): same key, enable Maps JavaScript API.
# Preferred variable name for Facility Vault drawing tools:
#   VITE_GOOGLE_MAPS_API_KEY=AIza...
# Legacy fallback used elsewhere:
#   VITE_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
