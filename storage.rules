rules_version = '2';

// Phoenix Sprint 7.3 — club branding logos (Zero-Trust writes; public read for CDN caching).
service firebase.storage {
  match /b/{bucket}/o {
    match /clubs/{clubId}/branding/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
        && request.auth.token.role in ['director', 'registrar']
        && request.auth.token.clubId == clubId
        && fileName == 'logo.png'
        && request.resource != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType in [
          'image/png',
          'image/jpeg',
          'image/webp'
        ];
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
