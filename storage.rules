rules_version = '2';

// Phoenix Sprint 7.3 — club branding logos (Zero-Trust writes; public read for CDN caching).
service firebase.storage {
  match /b/{bucket}/o {
    match /clubs/{clubId}/branding/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
        && request.auth.token.role in ['director', 'registrar']
        && request.auth.token.clubId == clubId
        && fileName == 'logo.png'
        && request.resource != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType in [
          'image/png',
          'image/jpeg',
          'image/webp'
        ];
    }

    // Epic 14: verified video trials (player upload; coach/recruiter read).
    // Epic 17 Phase 1 — facility map vault (PDF / images; director upload; club-scoped read).
    match /clubs/{clubId}/facility_maps/{mapId} {
      allow read: if request.auth != null
        && (
          request.auth.token.role == 'super_admin'
          || request.auth.token.clubId == clubId
        );

      allow write: if request.auth != null
        && request.auth.token.role == 'director'
        && request.auth.token.clubId == clubId
        && request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    match /clubs/{clubId}/trials/{playerId}/{fileName} {
      allow read: if request.auth != null
        && (
          request.auth.uid == playerId
          || request.auth.token.role == 'super_admin'
          || (
            request.auth.token.clubId == clubId
            && request.auth.token.role in ['director', 'coach', 'registrar']
          )
          || request.auth.token.tier == 'recruiter'
        );

      allow write: if request.auth != null
        && request.auth.uid == playerId
        && fileName.matches('.*_video\\.mp4')
        && request.resource != null
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // ─────────────────────────────────────────────────────────────────────
    // EPIC 5 — TASK 5.4: PLAYER DOCUMENT VAULT (Principle of Least Privilege)
    //
    // Path layout:
    //   /tenants/{tenantId}/players/{uid}/public/{fileName}
    //   /tenants/{tenantId}/players/{uid}/private/{fileName}
    //
    // tenantId check: validates BOTH tenantId and clubId JWT claims so that
    // legacy JWTs (only clubId set) and new JWTs (both set) are accepted.
    //
    // Platform admins (super_admin / global_admin) bypass tenant checks.
    // ─────────────────────────────────────────────────────────────────────

    // Helper functions — Firebase Storage rules do not share helpers across
    // match blocks, so they are inlined as one-liners here.

    match /tenants/{tenantId}/players/{uid}/public/{fileName} {
      // Public: profile photos, headshots — readable by any authenticated
      // member of the same tenant. No cross-tenant read possible.
      allow read: if request.auth != null
        && (
          request.auth.token.role in ['super_admin', 'global_admin']
          || request.auth.token.tenantId == tenantId
          || request.auth.token.clubId == tenantId
        );

      // Write: only the player themselves (uid match) within their tenant.
      // Content-type and size gated: profile photos only (no PDFs in public).
      allow write: if request.auth != null
        && request.auth.uid == uid
        && (
          request.auth.token.tenantId == tenantId
          || request.auth.token.clubId == tenantId
          || request.auth.token.role in ['super_admin', 'global_admin']
        )
        && request.resource != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType in ['image/png', 'image/jpeg', 'image/webp'];

      allow delete: if request.auth != null
        && request.auth.uid == uid
        && (
          request.auth.token.tenantId == tenantId
          || request.auth.token.clubId == tenantId
          || request.auth.token.role in ['super_admin', 'global_admin']
        );
    }

    match /tenants/{tenantId}/players/{uid}/private/{fileName} {
      // Private: birth certificates, photo IDs, medical forms.
      //
      // CLIENT READS ARE BLOCKED (allow read: if false).
      // Access is only via the getSensitiveDocumentUrl Cloud Function, which:
      //   1. Validates the requester is a director for the correct tenant
      //   2. Writes an immutable audit_log entry with actorUid, targetUid,
      //      action='VIEW_PII', documentType, timestamp, ipAddress
      //   3. Returns a 5-minute signed URL (Admin SDK, bypasses these rules)
      //
      // This ensures every single private document access is audit-logged.
      allow read: if false;

      // Write: player uploads their own documents, OR a director uploads
      // on their behalf (e.g., during club registration intake).
      allow write: if request.auth != null
        && (
          // Player self-upload
          (
            request.auth.uid == uid
            && (
              request.auth.token.tenantId == tenantId
              || request.auth.token.clubId == tenantId
            )
          )
          ||
          // Director upload on behalf of player
          (
            request.auth.token.role == 'director'
            && (
              request.auth.token.tenantId == tenantId
              || request.auth.token.clubId == tenantId
            )
          )
          ||
          // Platform admin
          request.auth.token.role in ['super_admin', 'global_admin']
        )
        && request.resource != null
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp|gif)|application/pdf');

      // Delete: director for their tenant, or platform admin.
      // Players may NOT delete their own sensitive docs (prevents evidence destruction).
      allow delete: if request.auth != null
        && (
          (
            request.auth.token.role == 'director'
            && (
              request.auth.token.tenantId == tenantId
              || request.auth.token.clubId == tenantId
            )
          )
          || request.auth.token.role in ['super_admin', 'global_admin']
        );
    }

    // ─────────────────────────────────────────────────────────────────────
    // EPIC 9 — SECURE MEDIA VAULT
    //
    // Path layout:
    //   tenants/{tenantId}/staging/{uid}/{fileName}   ← write-once upload zone
    //   tenants/{tenantId}/media/{uid}/{fileName}     ← CF-only write, tenant-scoped read
    //   tenants/{tenantId}/quarantine/{uid}/{fileName} ← CF-only, no client access
    //
    // Upload flow:
    //   1. Client calls getUploadToken CF → receives a V4 signed PUT URL
    //      (bypasses these rules; signed URLs use service-account authority)
    //   2. processMedia CF triggers on staging/ creation:
    //      a. Strips EXIF / container metadata
    //      b. Runs Gemini safety scan
    //      c. Moves to media/ or quarantine/
    //      d. Deletes the staging file
    //   3. Client reads media/ via signed URLs (no direct Storage auth required)
    //
    // These rules provide defence-in-depth: even if a signed URL is leaked,
    // the staging bucket blocks direct client reads, and quarantine is sealed.
    // ─────────────────────────────────────────────────────────────────────

    // STAGING bucket — write-once by authenticated players; NO client reads.
    // Reads are done exclusively by the processMedia Cloud Function (Admin SDK,
    // which bypasses these rules).
    match /tenants/{tenantId}/staging/{uid}/{fileName} {
      // Authenticated player may upload to their own UID slot within their tenant.
      // NOTE: In production, use getUploadToken CF for V4 signed PUT URLs instead.
      //       This rule is a fallback for emulator/test environments.
      allow write: if request.auth != null
        && request.auth.uid == uid
        && (
          request.auth.token.tenantId == tenantId
          || request.auth.token.clubId == tenantId
          || request.auth.token.role in ['super_admin', 'global_admin']
        )
        && request.resource != null
        && request.resource.size <= 100 * 1024 * 1024
        && request.resource.contentType.matches(
          'video/mp4|video/webm|video/quicktime|image/(jpeg|png|webp)'
        );

      // NO client reads of staging files. processMedia CF uses Admin SDK.
      allow read: if false;

      // NO client deletes — processMedia CF deletes staging files after processing.
      allow delete: if false;
    }

    // PROCESSED MEDIA bucket — read by authenticated tenant members; writes
    // are reserved for the processMedia Cloud Function (Admin SDK).
    // Players, coaches, and directors can stream ready clips.
    // Recruiters with an accepted handshake can also read (enforced by Firestore,
    // not Storage rules, via signed URL generation in the CF).
    match /tenants/{tenantId}/media/{uid}/{fileName} {
      allow read: if request.auth != null
        && (
          request.auth.token.role in ['super_admin', 'global_admin']
          || request.auth.uid == uid
          || (
            (
              request.auth.token.tenantId == tenantId
              || request.auth.token.clubId == tenantId
            )
            && request.auth.token.role in ['director', 'coach', 'player', 'parent', 'tutor']
          )
        );

      // NO client writes — processMedia CF handles all writes via Admin SDK.
      allow write: if false;

      // Players can delete their own processed clips; directors can delete any.
      allow delete: if request.auth != null
        && (
          request.auth.uid == uid
          || request.auth.token.role in ['director', 'super_admin', 'global_admin']
        )
        && (
          request.auth.token.tenantId == tenantId
          || request.auth.token.clubId == tenantId
          || request.auth.token.role in ['super_admin', 'global_admin']
        );
    }

    // QUARANTINE bucket — completely sealed from clients.
    // Only platform admins can review (via Admin SDK / Console).
    match /tenants/{tenantId}/quarantine/{uid}/{fileName} {
      allow read, write, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // EPIC 14 (ALPHA) — COACH COMPLIANCE VAULT
    //
    // Path layout:
    //   /compliance/{tenantId}/{userId}/{fileName}
    //
    // Coaches/Recruiters upload SafeSport & Concussion certs to their own
    // UID slot.  Directors and Registrars may read every file in their
    // tenant to review and approve.  Only platform admins may delete.
    // ─────────────────────────────────────────────────────────────────────
    match /compliance/{tenantId}/{userId}/{fileName} {
      // Write: only the owning coach/recruiter, within their tenant.
      // 10 MB max; PDF or image only.
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (
          request.auth.token.tenantId == tenantId
          || request.auth.token.clubId == tenantId
        )
        && request.auth.token.role in ['coach', 'recruiter']
        && request.resource != null
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)|application/pdf');

      // Read: owner OR director/registrar within the same tenant OR platform admin.
      allow read: if request.auth != null
        && (
          request.auth.uid == userId
          || request.auth.token.role in ['super_admin', 'global_admin']
          || (
            request.auth.token.role in ['director', 'registrar']
            && (
              request.auth.token.tenantId == tenantId
              || request.auth.token.clubId == tenantId
            )
          )
        );

      // Delete: director/registrar for their tenant, or platform admin only.
      allow delete: if request.auth != null
        && (
          request.auth.token.role in ['super_admin', 'global_admin']
          || (
            request.auth.token.role in ['director', 'registrar']
            && (
              request.auth.token.tenantId == tenantId
              || request.auth.token.clubId == tenantId
            )
          )
        );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
