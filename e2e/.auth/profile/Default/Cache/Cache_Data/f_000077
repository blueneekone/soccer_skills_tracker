; padding: 20px; text-align: center; border: 1px solid rgba(0, 0, 0, 0.08); border-radius: var(--radius-premium); }\r\n.challenge-banner-title { margin: 0 0 5px 0; font-weight: 600; }\r\n.challenge-banner-text { margin: 0; font-weight: 700; font-size: 1rem; }\r\n\r\n/* Grid Layout — Bento: min column floor so tiles wrap instead of crushing */\r\n.dashboard-grid,\r\n.bento-grid {\r\n    display: grid;\r\n    grid-template-columns: repeat(auto-fit, minmax(min(100%, clamp(280px, 30vw, 350px)), 1fr));\r\n    gap: var(--grid-gap-bento);\r\n    margin-bottom: var(--spacing-fluid);\r\n}\r\n.dash-card {\r\n    cursor: pointer;\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    justify-content: center;\r\n    text-align: center;\r\n    padding: clamp(20px, 4vw, 30px) 16px;\r\n    margin-bottom: 0;\r\n    transition: all 0.2s ease-out;\r\n    border-radius: var(--radius-premium);\r\n}\r\n.dash-card:hover {\r\n    transform: none;\r\n    opacity: 0.96;\r\n    box-shadow:\r\n        0 1px 2px rgba(0, 0, 0, 0.05),\r\n        0 12px 24px -8px rgba(0, 0, 0, 0.08);\r\n}\r\n.dash-card:active {\r\n    transform: scale(0.98);\r\n    opacity: 1;\r\n}\r\n.dash-card-body {\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    gap: 8px;\r\n    width: 100%;\r\n    min-width: 0;\r\n}\r\n.dash-icon {\r\n    font-size: 3rem;\r\n    margin-bottom: 15px;\r\n    color: var(--text-primary);\r\n    flex-shrink: 0;\r\n}\r\n.icon-large { font-size: 4rem; margin-bottom: 20px; }\r\n.dash-label { font-weight: 600; font-size: 1.1rem; }\r\n.challenge-title-gold { color: var(--text-primary); font-weight: 600; }\r\n\r\nhtml.dark .challenge-title-gold {\r\n    color: var(--text-primary);\r\n}\r\n\r\n/* ==========================================\r\n   6. LISTS & TABLES\r\n   ========================================== */\r\n.session-list { list-style: none; padding: 0; margin: 0; }\r\n.flush-list { margin: 0 calc(var(--spacing-fluid) * -1)