const __vite__css = "/* =======================================================\r\n   SSTRACKER — global design system (enterprise console)\r\n   ======================================================= */\r\n/* Sprint 9.3: Inter import removed — Geist Sans is the canonical sans font (loaded in app.html) */\r\n\r\n:root {\r\n    /* Brand — use only for active controls, meters, accents */\r\n    --aggie-blue: #0a0a0a;\r\n    --aggie-gold: #d4d4d4;\r\n    --brand-primary: #6366f1;\r\n    --brand-accent: #10b981;\r\n    --club-logo-url: none;\r\n    --success-green: #16a34a;\r\n    --danger-red: #991b1b;\r\n    --muted-slate: #737373;\r\n    --light-blue: #f4f4f5;\r\n\r\n    --text-primary: #0a0a0a;\r\n    --text-secondary: #737373;\r\n    --text-on-gold: #0a0a0a;\r\n    --accent-orange: #9a3412;\r\n    --accent-orange-soft: #9a3412;\r\n    --focus-ring-color: rgba(10, 10, 10, 0.15);\r\n\r\n    --chart-bar: #0a0a0a;\r\n    --chart-tick: #737373;\r\n    --chart-grid: rgba(0, 0, 0, 0.08);\r\n\r\n    /* Enterprise surfaces — Vanguard dark-mode-first slate tokens (Sprint 9.3: cyan fallbacks purged) */\r\n    --glass-bg:         var(--vanguard-glass,    rgba(19, 28, 46, 0.72));\r\n    --glass-border:     var(--vanguard-border,   #1e293b);\r\n    --glass-edge-light: var(--vanguard-border,   #1e293b);\r\n    --glass-edge-dark:  var(--vanguard-border,   #1e293b);\r\n    --glass-panel-edge: var(--vanguard-border,   #1e293b);\r\n    --surface-row-hover: rgba(148, 163, 184, 0.04);\r\n    --surface-subtle: #0a0e1a;\r\n    --border-subtle: rgba(30, 41, 59, 0.8);\r\n    --border-strong: #1e293b;\r\n    --input-bg: rgba(15, 23, 42, 0.6);\r\n    --input-border: #1e293b;\r\n    --input-text: var(--text-primary);\r\n\r\n    /* Radius — deferred to Vanguard tokens (still resolves to 24px) */\r\n    --radius-premium: var(--vanguard-radius,    1.5rem);\r\n    --radius-inner:   var(--vanguard-radius-sm, 0.75rem);\r\n    --radius-pill: 9999px;\r\n    --spacing-fluid: clamp(16px, 3.5vw, 28px);\r\n    --spacing-element: 16px;\r\n    /* Shadows — deferred to Vanguard elevation tokens */\r\n    --shadow-premium: var(--vanguard-elev-1,\r\n        inset 0 1px 0 rgba(255, 255, 255, 0.04),\r\n        0 1px 2px rgba(0, 0, 0, 0.4),\r\n        0 4px 12px -4px rgba(0, 0, 0, 0.5));\r\n    --shadow-liquid: var(--vanguard-elev-2,\r\n        inset 0 1px 0 rgba(255, 255, 255, 0.06),\r\n        0 1px 2px rgba(0, 0, 0, 0.3),\r\n        0 8px 24px -8px rgba(0, 0, 0, 0.5));\r\n    --shell-padding-x: clamp(1rem, 5vw, 3rem);\r\n    --shell-padding-y: clamp(0.75rem, 2.5vw, 1.5rem);\r\n    --grid-gap-bento: clamp(1rem, 2.8vw, 2rem);\r\n\r\n    --enterprise-primary-bg: #0a0a0a;\r\n    --enterprise-primary-fg: #ffffff;\r\n\r\n    /* Sprint 2.6.5 — enterprise console canvas token (was falling back to\r\n       hard-coded #f4f4f5 in enterprise-console.css). */\r\n    --ec-canvas-bg: #f4f4f5;\r\n\r\n    /* Operations accent — muted teal (Sprint 9.3: replaced neon cyan) */\r\n    --ec-ops-accent: #14b8a6;\r\n}\r\n\r\n/* Elite Player Portal — same enterprise dark canvas */\r\nhtml.player-elite.dark body {\r\n    background: #09090b;\r\n}\r\n\r\n/* Athlete shell — enterprise dark tokens */\r\nhtml.player-portal-theme {\r\n    --pp-bg-rich: #09090b;\r\n    --pp-text: #fafafa;\r\n    --pp-text-body: #a3a3a3;\r\n    --pp-text-muted: #a3a3a3;\r\n    --pp-card-glow: inset 0 1px 0 0 rgba(255, 255, 255, 0.06);\r\n    color-scheme: dark;\r\n}\r\n\r\nhtml.player-portal-theme body {\r\n    background: var(--pp-bg-rich);\r\n    color: var(--pp-text-body);\r\n}\r\n\r\nhtml.player-portal-theme .app-title,\r\nhtml.player-portal-theme h1,\r\nhtml.player-portal-theme h2,\r\nhtml.player-portal-theme h3,\r\nhtml.player-portal-theme .welcome-title {\r\n    color: var(--pp-text);\r\n}\r\n\r\nhtml.player-portal-theme .player-info,\r\nhtml.player-portal-theme .welcome-subtitle {\r\n    color: var(--pp-text-muted);\r\n}\r\n\r\nhtml.player-portal-theme .card,\r\nhtml.player-portal-theme .welcome-brand-wrap,\r\nhtml.player-portal-theme .glass-panel {\r\n    /* shadow-liquid now defers to --vanguard-elev-2 which already includes multi-layer depth;\r\n       pp-card-glow adds the inset top highlight for the player portal */\r\n    box-shadow: var(--shadow-liquid), var(--pp-card-glow);\r\n}\r\n\r\n/* ==========================================\r\n   1. GLOBAL FOUNDATION & UTILITIES\r\n   ========================================== */\r\nbody {\r\n    background: #fafafa;\r\n    font-family: 'Geist', 'Inter', ui-sans-serif, system-ui, sans-serif;\r\n    letter-spacing: -0.01em;\r\n    margin: 0;\r\n    color: var(--text-primary);\r\n    line-height: 1.6;\r\n}\r\n\r\nh1,\r\nh2,\r\nh3,\r\nh4,\r\nh5,\r\nh6,\r\n.app-title,\r\n.welcome-title,\r\n.auth-title {\r\n    letter-spacing: -0.03em;\r\n    font-weight: 600;\r\n}\r\n\r\n.container {\r\n    max-width: 1000px;\r\n    margin: 0 auto;\r\n    box-sizing: border-box;\r\n}\r\n.app-main {\r\n    padding-top: clamp(4rem, 10vw, 5rem);\r\n    padding-bottom: clamp(5rem, 12vw, 6.25rem);\r\n    padding-inline: var(--shell-padding-x);\r\n    min-height: 100vh;\r\n    box-sizing: border-box;\r\n}\r\n/* Vertical rhythm only — horizontal shell padding lives on .app-main (avoids double gutters) */\r\n.view-section {\r\n    padding-block: var(--shell-padding-y);\r\n    padding-inline: 0;\r\n    width: 100%;\r\n    box-sizing: border-box;\r\n    min-width: 0;\r\n}\r\n.full-screen-center { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; box-sizing: border-box; }\r\n\r\n/* SvelteKit root wrapper: no layout box so app content participates in body flow */\r\n.sveltekit-body-root { display: contents; }\r\n\r\n/* Utilities */\r\n.d-none { display: none !important; }\r\n.auth-error-msg {\r\n    color: var(--danger-red);\r\n    font-size: 0.9rem;\r\n    font-weight: 600;\r\n    margin: 10px 0 0;\r\n    text-align: center;\r\n}\r\n.w-100 { width: 100%; box-sizing: border-box; }\r\n.w-50 { width: 50px; text-align: center; }\r\n.flex-1 { flex: 1; }\r\n.flex-2 { flex: 2; }\r\n.mb-10 { margin-bottom: 10px; }\r\n.mb-15 { margin-bottom: 15px; }\r\n.mb-20-imp { margin-bottom: 20px !important; }\r\n.mt-0 { margin-top: 0; }\r\n.mt-10 { margin-top: 10px; }\r\n.mt-15 { margin-top: 15px; }\r\n.mt-20 { margin-top: 20px; }\r\n.m-0 { margin: 0 !important; }\r\n.p-0 { padding: 0 !important; }\r\n.p-20 { padding: 20px; }\r\n.text-center { text-align: center; }\r\n.text-left { text-align: left; }\r\n.font-bold { font-weight: 700; }\r\n.text-white { color: white !important; }\r\n.text-sm { font-size: 0.9rem; }\r\n.text-sm-sub { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; }\r\n.cursor-pointer { cursor: pointer; }\r\n.no-underline { text-decoration: none; }\r\n.flush-top { margin-top: 0 !important; border-top-left-radius: 0; border-top-right-radius: 0; }\r\n\r\n/* Layout hardening — flex/grid: text truncates, chrome does not compress */\r\n.min-w-0 { min-width: 0; }\r\n.shrink-0 { flex-shrink: 0; }\r\n\r\n/* Accessible accent text (theme-aware; avoids inline styles) */\r\n.text-accent-orange { color: var(--accent-orange-soft); font-weight: 700; }\r\n.text-admin-mono { color: #0369a1; font-weight: 700; }\r\nhtml.dark .text-admin-mono { color: #7dd3fc; }\r\n\r\n/* Linked / success chip (roster, etc.) */\r\n.linked-badge-ui {\r\n    flex-shrink: 0;\r\n    background: rgba(4, 120, 87, 0.12);\r\n    color: #065f46;\r\n    border: 1px solid rgba(4, 120, 87, 0.35);\r\n    border-radius: 6px;\r\n    padding: 2px 8px;\r\n    font-size: 0.75rem;\r\n    font-weight: 600;\r\n}\r\nhtml.dark .linked-badge-ui {\r\n    background: rgba(52, 211, 153, 0.14);\r\n    color: #d1fae5;\r\n    border-color: rgba(52, 211, 153, 0.4);\r\n}\r\n\r\n/* ==========================================\r\n   2. LIQUID GLASS CARDS\r\n   ========================================== */\r\n.card, .auth-card {\r\n    background: var(--glass-bg);\r\n    border-radius: var(--radius-premium);\r\n    border: 1px solid var(--glass-border);\r\n    box-shadow: var(--shadow-premium);\r\n    padding: var(--spacing-fluid);\r\n    margin-bottom: var(--spacing-fluid);\r\n    transition: box-shadow 0.2s ease;\r\n    box-sizing: border-box;\r\n}\r\n\r\n.card:hover,\r\n.auth-card:hover {\r\n    transform: none;\r\n    box-shadow:\r\n        0 1px 2px rgba(0, 0, 0, 0.05),\r\n        0 12px 24px -8px rgba(0, 0, 0, 0.06);\r\n}\r\n\r\n/* Epic 1.2: multi-card bento rows (fluid gap, no double margins) */\r\n.bento-section {\r\n    display: grid;\r\n    grid-template-columns: repeat(auto-fit, minmax(min(100%, clamp(280px, 30vw, 350px)), 1fr));\r\n    gap: var(--grid-gap-bento);\r\n    align-items: start;\r\n    margin-bottom: var(--grid-gap-bento);\r\n}\r\n\r\n.bento-section > .card {\r\n    margin-bottom: 0;\r\n}\r\n\r\n.bento-section-tight {\r\n    grid-template-columns: repeat(auto-fit, minmax(min(100%, clamp(240px, 28vw, 320px)), 1fr));\r\n}\r\n\r\n.bento-span-full {\r\n    grid-column: 1 / -1;\r\n}\r\n/* Card section titles — calm enterprise rhythm */\r\n.card-header {\r\n    font-size: 0.9375rem;\r\n    font-weight: 800;\r\n    letter-spacing: -0.02em;\r\n    line-height: 1.25;\r\n    padding: 0 0 14px;\r\n    margin: 0 0 var(--spacing-element);\r\n    border-bottom: 1px solid var(--border-subtle);\r\n    color: var(--text-primary);\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    flex-wrap: wrap;\r\n    gap: 10px;\r\n    min-width: 0;\r\n    background: transparent;\r\n}\r\n.card-header > * {\r\n    min-width: 0;\r\n}\r\n.card-header > button,\r\n.card-header > a[role='button'],\r\n.card-header > .card-header-actions {\r\n    flex-shrink: 0;\r\n    min-width: auto;\r\n}\r\n.card-body > * + * { margin-top: var(--spacing-element); }\r\n\r\n/* Sprint 1.1 / Phase 1: Vanguard glassmorphism — dark-mode-first true glass */\r\n.glass-panel {\r\n    border-radius: var(--radius-premium);\r\n    border: 1px solid var(--glass-panel-edge);\r\n    background: var(--glass-bg);\r\n    backdrop-filter: blur(var(--vanguard-blur, 24px)) saturate(1.8);\r\n    -webkit-backdrop-filter: blur(var(--vanguard-blur, 24px)) saturate(1.8);\r\n    box-shadow: var(--shadow-liquid);\r\n}\r\n\r\nhtml.dark .glass-panel,\r\nhtml.recruiter-scout-theme .glass-panel {\r\n    background: rgba(0, 20, 30, 0.6);\r\n    border-color: var(--vanguard-border, #1e293b);\r\n    backdrop-filter: blur(var(--vanguard-blur, 24px)) saturate(1.8);\r\n    -webkit-backdrop-filter: blur(var(--vanguard-blur, 24px)) saturate(1.8);\r\n}\r\n\r\n/* =============================================================\r\n   SPRINT 1.1 — GLOBAL BENTO GRID SYSTEM\r\n   Use .bento-grid as the container, .bento-card for each cell.\r\n   Modifier classes: --3, --4 unlock 3/4-col breakpoints.\r\n   .bento-card--glass adds backdrop-filter glassmorphism.\r\n   .bento-card--full spans all columns.\r\n   ============================================================= */\r\n.bento-grid {\r\n    display: grid;\r\n    grid-template-columns: 1fr;\r\n    gap: var(--grid-gap-bento);\r\n    align-items: stretch;\r\n    width: 100%;\r\n    box-sizing: border-box;\r\n}\r\n\r\n@media (min-width: 40rem) {\r\n    .bento-grid {\r\n        grid-template-columns: repeat(2, minmax(0, 1fr));\r\n    }\r\n}\r\n\r\n@media (min-width: 64rem) {\r\n    .bento-grid--3 {\r\n        grid-template-columns: repeat(3, minmax(0, 1fr));\r\n    }\r\n}\r\n\r\n@media (min-width: 80rem) {\r\n    .bento-grid--4 {\r\n        grid-template-columns: repeat(4, minmax(0, 1fr));\r\n    }\r\n}\r\n\r\n.bento-card {\r\n    display: flex;\r\n    flex-direction: column;\r\n    border-radius: var(--radius-premium);\r\n    border: 1px solid var(--glass-panel-edge);\r\n    background: #ffffff;\r\n    box-shadow: var(--shadow-liquid);\r\n    padding: var(--spacing-fluid);\r\n    box-sizing: border-box;\r\n    min-width: 0;\r\n    container-type: inline-size;\r\n    container-name: bento;\r\n}\r\n\r\n.bento-card--full {\r\n    grid-column: 1 / -1;\r\n}\r\n\r\n.bento-card--glass {\r\n    background: var(--glass-bg);\r\n    backdrop-filter: blur(var(--vanguard-blur, 24px)) saturate(1.8);\r\n    -webkit-backdrop-filter: blur(var(--vanguard-blur, 24px)) saturate(1.8);\r\n}\r\n\r\nhtml.dark .bento-card {\r\n    background: rgba(0, 20, 30, 0.5);\r\n    border-color: var(--vanguard-border, #1e293b);\r\n}\r\n\r\nhtml.dark .bento-card--glass {\r\n    background: rgba(0, 20, 30, 0.6);\r\n    backdrop-filter: blur(var(--vanguard-blur, 24px)) saturate(1.8);\r\n    -webkit-backdrop-filter: blur(var(--vanguard-blur, 24px)) saturate(1.8);\r\n}\r\n\r\n/* Themed Borders & Headers — 1px, flat fills */\r\n.border-gold { border: 1px solid #d4d4d4; }\r\n.border-green { border: 1px solid var(--success-green); }\r\n.border-gray { border: 1px solid #d4d4d4; }\r\n.border-slate { border: 1px solid #a3a3a3; }\r\n.border-purple { border: 1px solid #737373; }\r\n.border-orange { border: 1px solid #ea580c; }\r\n.border-aggie-blue { border: 1px solid var(--text-primary); }\r\n\r\n/* Semantic section rails — left accent + neutral surface (replaces flat color blocks) */\r\n.bg-blue-header,\r\n.bg-gold-header,\r\n.bg-red-header,\r\n.bg-green-header,\r\n.bg-orange-header {\r\n    padding: 14px var(--spacing-fluid) 16px;\r\n    margin: calc(var(--spacing-fluid) * -1) calc(var(--spacing-fluid) * -1) var(--spacing-element)\r\n        calc(var(--spacing-fluid) * -1);\r\n    border-radius: var(--radius-premium) var(--radius-premium) 0 0;\r\n    border-bottom: 1px solid var(--border-subtle);\r\n    color: var(--text-primary);\r\n    font-size: 0.9375rem;\r\n    font-weight: 800;\r\n    letter-spacing: -0.02em;\r\n    background: linear-gradient(90deg, rgba(0, 0, 0, 0.03), transparent 40%);\r\n    border-left: 3px solid var(--card-header-accent, var(--ec-ops-accent));\r\n    padding-left: calc(var(--spacing-fluid) - 3px);\r\n}\r\n.bg-blue-header {\r\n    --card-header-accent: #6366f1;\r\n    background: linear-gradient(90deg, rgba(99, 102, 241, 0.09), transparent 45%);\r\n}\r\n.bg-gold-header {\r\n    --card-header-accent: #ca8a04;\r\n    background: linear-gradient(90deg, rgba(234, 179, 8, 0.1), transparent 45%);\r\n}\r\n.bg-red-header {\r\n    --card-header-accent: #ef4444;\r\n    background: linear-gradient(90deg, rgba(239, 68, 68, 0.1), transparent 45%);\r\n}\r\n.bg-green-header {\r\n    --card-header-accent: #22c55e;\r\n    background: linear-gradient(90deg, rgba(34, 197, 94, 0.1), transparent 45%);\r\n}\r\n.bg-orange-header {\r\n    --card-header-accent: #ea580c;\r\n    background: linear-gradient(90deg, rgba(234, 88, 12, 0.1), transparent 45%);\r\n}\r\nhtml.dark .bg-blue-header,\r\nhtml.dark .bg-gold-header,\r\nhtml.dark .bg-red-header,\r\nhtml.dark .bg-green-header,\r\nhtml.dark .bg-orange-header {\r\n    color: #fafafa;\r\n    border-bottom-color: rgba(255, 255, 255, 0.1);\r\n    background: linear-gradient(90deg, rgba(255, 255, 255, 0.05), transparent 50%);\r\n}\r\nhtml.dark .bg-blue-header {\r\n    background: linear-gradient(90deg, rgba(99, 102, 241, 0.14), transparent 50%);\r\n}\r\nhtml.dark .bg-gold-header {\r\n    background: linear-gradient(90deg, rgba(234, 179, 8, 0.12), transparent 50%);\r\n}\r\nhtml.dark .bg-red-header {\r\n    background: linear-gradient(90deg, rgba(239, 68, 68, 0.14), transparent 50%);\r\n}\r\nhtml.dark .bg-green-header {\r\n    background: linear-gradient(90deg, rgba(34, 197, 94, 0.14), transparent 50%);\r\n}\r\nhtml.dark .bg-orange-header {\r\n    background: linear-gradient(90deg, rgba(234, 88, 12, 0.14), transparent 50%);\r\n}\r\n\r\n/* Page titles (athlete / household views) */\r\n.view-title {\r\n    font-size: clamp(1.2rem, 3.2vw, 1.65rem);\r\n    font-weight: 900;\r\n    letter-spacing: -0.035em;\r\n    line-height: 1.12;\r\n    color: var(--text-primary);\r\n    margin: 0 0 1rem;\r\n}\r\nhtml.dark .view-title {\r\n    color: #fafafa;\r\n}\r\n\r\n/* ==========================================\r\n   3. AUTHENTICATION UI & PWA PROMPT\r\n   ========================================== */\r\n.auth-card { max-width: 440px; width: 95%; margin: auto; text-align: center; padding: 40px var(--spacing-fluid); }\r\n.logo-circle { width: 80px; height: 80px; background: #0a0a0a; border-radius: 50%; margin: 0 auto 24px auto; display: flex; align-items: center; justify-content: center; font-size: 40px; box-shadow: var(--shadow-premium); color: #fafafa; }\r\n.logo-circle .ph { font-size: 2.25rem; line-height: 1; }\r\n.auth-title { font-size: 1.75rem; font-weight: 600; margin: 0 0 8px 0; }\r\n.auth-subtitle { color: var(--text-secondary); margin: 0 0 32px 0; font-size: 0.95rem; font-weight: 600; }\r\n.auth-divider { display: flex; align-items: center; margin: 24px 0; }\r\n.divider-line { flex-grow: 1; border: none; border-top: 1px solid var(--border-subtle); }\r\n.divider-text { margin: 0 16px; color: var(--text-secondary); font-size: 0.85rem; font-weight: 700; }\r\n.setup-helper-text { font-size: 0.8rem; color: var(--danger-red); font-weight: 600; margin-bottom: 20px; }\r\n\r\n/* PWA Install Prompt */\r\n.pwa-prompt { background: #0a0a0a; color: white; padding: 20px; border-radius: var(--radius-premium); margin-top: 20px; max-width: 440px; width: 95%; text-align: left; box-shadow: var(--shadow-premium); border: 1px solid rgba(255, 255, 255, 0.1); }\r\n.pwa-title { margin: 0 0 10px 0; font-weight: 600; font-size: 1.2rem; }\r\n.pwa-text { font-size: 0.9rem; margin-bottom: 15px; color: #e2e8f0; }\r\n.pwa-box { background: rgba(255,255,255,0.12); padding: 15px; border-radius: 12px; font-size: 0.85rem; margin-bottom: 15px; color: #f1f5f9; border: 1px solid rgba(255, 255, 255, 0.18); }\r\n\r\n/* ==========================================\r\n   4. INPUTS & CHUNKY BUTTONS\r\n   ========================================== */\r\nlabel { display: block; text-align: left; font-weight: 600; font-size: 0.9rem; margin-bottom: 6px; color: var(--text-primary); }\r\n\r\n/* Text-like fields: premium radius (caps at 12px so fi