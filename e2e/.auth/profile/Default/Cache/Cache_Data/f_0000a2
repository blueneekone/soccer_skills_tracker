const __vite__css = "/**\r\n * Universal enterprise shell — locked viewport (100vh), sidebar, canvas.\r\n * Imported by EnterpriseConsoleShell for all authenticated app roles.\r\n */\r\n\r\n/* Operations-console accent (SOC-adjacent) — shared with workspace dashboards */\r\n:root {\r\n\t--ec-ops-accent: #14b8a6;               /* Muted teal — replaces neon cyan */\r\n\t--ec-ops-accent-dim: rgba(20, 184, 166, 0.45);\r\n\t--ec-ops-sheen: rgba(20, 184, 166, 0.08);\r\n\t--ec-ops-ambient: rgba(20, 184, 166, 0.03);\r\n\t--ec-ops-glow: none;                    /* was: 0 0 42px rgba(20, 184, 166,0.05) */\r\n\t--ec-ops-border-subtle: rgba(148, 163, 184, 0.14); /* Slate, NOT teal */\r\n\r\n\t/* Icon stroke system — 1.5 mathematically matches Geist Mono cap stroke */\r\n\t--icon-stroke: 1.5;\r\n\t--icon-size-xs: 12px;\r\n\t--icon-size-sm: 14px;\r\n\t--icon-size-md: 16px;\r\n\t--icon-size-lg: 20px;\r\n\t--icon-size-xl: 24px;\r\n}\r\n\r\n.ec-root {\r\n\tdisplay: flex;\r\n\tflex-direction: row;\r\n\talign-items: stretch;\r\n\twidth: 100%;\r\n\tmax-width: 100%;\r\n\theight: 100dvh;\r\n\tmax-height: 100dvh;\r\n\toverflow: hidden;\r\n\toverflow-x: hidden;\r\n\tbackground: var(--ec-canvas-bg, #f4f4f5);\r\n\tbox-sizing: border-box;\r\n\t/* Create an isolated stacking context so global overlays (OfflineBanner,\r\n\t   ImpersonationBanner, etc.) cannot accidentally paint over the mobile header. */\r\n\tisolation: isolate;\r\n}\r\n\r\n/* Main row: sidebar + canvas (desktop); mobile overrides below */\r\n.ec-root__body {\r\n\tflex: 1 1 auto;\r\n\tmin-width: 0;\r\n\tmin-height: 0;\r\n\tdisplay: flex;\r\n\tflex-direction: row;\r\n\talign-items: stretch;\r\n\t/* overflow-x intentionally NOT set here — setting it would create a stacking context\r\n\t   that causes the sidebar's absolutely-positioned context-switcher popover to paint\r\n\t   BEHIND the main canvas (later DOM sibling wins). Sidebar width constrains overflow. */\r\n}\r\n\r\n/* ---------- Field mode: mobile header + off-canvas nav (< 1024px) ---------- */\r\n.ec-mobile-header {\r\n\tdisplay: none;\r\n\talign-items: center;\r\n\tjustify-content: space-between;\r\n\tgap: 12px;\r\n\tmin-height: 56px;\r\n\tpadding: 0 12px 0 14px;\r\n\tbox-sizing: border-box;\r\n\tborder-bottom: 1px solid var(--ec-sidebar-border, #e5e5e5);\r\n\tbackground: var(--glass-bg, #ffffff);\r\n\tflex-shrink: 0;\r\n}\r\n\r\nhtml.dark .ec-mobile-header {\r\n\tbackground: #0f0f11;\r\n\tborder-bottom-color: rgba(255, 255, 255, 0.1);\r\n}\r\n\r\n.ec-mobile-header__brand {\r\n\tdisplay: flex;\r\n\talign-items: center;\r\n\tgap: 10px;\r\n\tmin-width: 0;\r\n}\r\n\r\n.ec-mobile-header__logo-fallback {\r\n\tfont-size: 1.35rem;\r\n\tcolor: var(--text-secondary);\r\n}\r\n\r\n.ec-mobile-header__titles {\r\n\tdisplay: flex;\r\n\tflex-direction: column;\r\n\tmin-width: 0;\r\n}\r\n\r\n.ec-mobile-header__name {\r\n\tfont-size: 14px;\r\n\tfont-weight: 600;\r\n\tcolor: var(--text-primary);\r\n\tletter-spacing: -0.02em;\r\n\tline-height: 1.2;\r\n\toverflow: hidden;\r\n\ttext-overflow: ellipsis;\r\n\twhite-space: nowrap;\r\n}\r\n\r\n.ec-mobile-header__sub {\r\n\tfont-size: 11px;\r\n\tfont-weight: 500;\r\n\tcolor: var(--text-secondary);\r\n\tline-height: 1.2;\r\n}\r\n\r\n.ec-mobile-header__hamburger {\r\n\tdisplay: inline-flex;\r\n\talign-items: center;\r\n\tjustify-content: center;\r\n\twidth: 44px;\r\n\theight: 44px;\r\n\tpadding: 0;\r\n\tborder: 1px solid transparent;\r\n\tborder-radius: var(--vanguard-radius-sm);\r\n\tbackground: transparent;\r\n\tcolor: var(--text-primary);\r\n\tcursor: pointer;\r\n\tflex-shrink: 0;\r\n\ttransition:\r\n\t\tbackground var(--motion-fast) var(--motion-ease),\r\n\t\tborder-color var(--motion-fast) var(--motion-ease);\r\n}\r\n\r\n.ec-mobile-header__hamburger:hover {\r\n\tbackground: rgba(0, 0, 0, 0.05);\r\n\tborder-color: rgba(0, 0, 0, 0.08);\r\n}\r\n\r\nhtml.dark .ec-mobile-header__hamburger:hover {\r\n\tbackground: rgba(255, 255, 255, 0.06);\r\n\tborder-color: rgba(255, 255, 255, 0.1);\r\n}\r\n\r\n.ec-nav-backdrop {\r\n\tdisplay: none;\r\n\tposition: fixed;\r\n\tleft: 0;\r\n\tright: 0;\r\n\ttop: 56px;\r\n\tbottom: 0;\r\n\tz-index: 998;\r\n\tbackground: rgba(0, 0, 0, 0.48);\r\n\topacity: 0;\r\n\tpointer-events: none;\r\n\ttransition: opacity var(--motion-base) ease-out;\r\n}\r\n\r\n.ec-nav-backdrop--open {\r\n\topacity: 1;\r\n\tpointer-events: auto;\r\n}\r\n\r\n.ec-sidebar__mobile-top {\r\n\tdisplay: none;\r\n\tflex-shrink: 0;\r\n\tpadding: 10px 12px;\r\n\tborder-bottom: 1px solid var(--ec-sidebar-border, #e5e5e5);\r\n}\r\n\r\nhtml.dark .ec-sidebar__mobile-top {\r\n\tborder-bottom-color: rgba(255, 255, 255, 0.1);\r\n}\r\n\r\n.ec-sidebar__close-btn {\r\n\tdisplay: inline-flex;\r\n\talign-items: center;\r\n\tgap: 8px;\r\n\twidth: 100%;\r\n\tjustify-content: center;\r\n\tpadding: 10px 12px;\r\n\tfont: inherit;\r\n\tfont-size: 13px;\r\n\tfont-weight: 600;\r\n\tcolor: var(--text-secondary);\r\n\tbackground: rgba(0, 0, 0, 0.04);\r\n\tborder: 1px solid rgba(0, 0, 0, 0.08);\r\n\tborder-radius: var(--vanguard-radius-sm);\r\n\tcursor: pointer;\r\n\ttransition:\r\n\t\tbackground var(--motion-fast) var(--motion-ease),\r\n\t\tcolor var(--motion-fast) var(--motion-ease);\r\n}\r\n\r\n.ec-sidebar__close-btn:hover {\r\n\tbackground: rgba(0, 0, 0, 0.07);\r\n\tcolor: var(--text-primary);\r\n}\r\n\r\nhtml.dark .ec-sidebar__close-btn {\r\n\tbackground: rgba(255, 255, 255, 0.06);\r\n\tborder-color: rgba(255, 255, 255, 0.1);\r\n}\r\n\r\nhtml.dark .ec-sidebar__close-btn:hover {\r\n\tbackground: rgba(255, 255, 255, 0.1);\r\n}\r\n\r\n/* Top-level sidebar must not clip the workspace switcher dropdown; nav scroll lives on .ec-sidebar__nav */\r\n.ec-sidebar {\r\n\twidth: 16rem;\r\n\tmax-width: 16rem;\r\n\tmin-width: 0;\r\n\tflex-shrink: 0;\r\n\tdisplay: flex;\r\n\tflex-direction: column;\r\n\theight: 100%;\r\n\tborder-right: 1px solid var(--ec-sidebar-border, #e5e5e5);\r\n\tbackground: var(--ec-sidebar-bg, #fafafa);\r\n\tbox-sizing: border-box;\r\n\ttransition:\r\n\t\twidth var(--motion-slow) var(--motion-ease),\r\n\t\tmax-width var(--motion-slow) var(--motion-ease),\r\n\t\tborder-color var(--motion-slow) var(--motion-ease);\r\n}\r\n\r\n.ec-sidebar__panel {\r\n\twidth: 16rem;\r\n\tmax-width: 16rem;\r\n\tflex: 1;\r\n\tmin-height: 0;\r\n\tmin-width: 0;\r\n\tdisplay: flex;\r\n\tflex-direction: column;\r\n\theight: 100%;\r\n\tbox-sizing: border-box;\r\n\ttransition: transform var(--motion-slow) var(--motion-ease);\r\n}\r\n\r\nhtml.dark .ec-sidebar {\r\n\tbackground: #09090b;\r\n\tborder-right-color: rgba(255, 255, 255, 0.1);\r\n}\r\n\r\n@media (min-width: 1024px) {\r\n\t/* Sprint 2.6.5 — Context Switcher bleed fix (P0).\r\n\t   • `.ec-sidebar` owns z-index: 50 so its absolutely-positioned popover\r\n\t     (`.ec-ws__popover`) lives above ALL canvas paint layers without any\r\n\t     overflow tricks.\r\n\t   • `.ec-main` deliberately does NOT set z-index. Adding one here would\r\n\t     create a competing stacking context that traps popovers behind the\r\n\t     canvas whenever the sidebar and main are siblings of the same\r\n\t     z-index tier. Paint order stays under the browser's default normal\r\n\t     flow, which is the source of truth for everything else on the page.\r\n\t   • NO `overflow: hidden` on .ec-main (that clipped DataTable action\r\n\t     dropdowns and tooltips). */\r\n\t.ec-sidebar {\r\n\t\tposition: relative;\r\n\t\tz-index: 50;\r\n\t}\r\n\r\n\t.ec-sidebar__panel {\r\n\t\toverflow: visible;\r\n\t}\r\n\r\n\t.ec-main {\r\n\t\tposition: relative;\r\n\t}\r\n\r\n\t.ec-sidebar--collapsed-desktop {\r\n\t\twidth: 0 !important;\r\n\t\tmax-width: 0 !important;\r\n\t\tmin-width: 0 !important;\r\n\t\tborder-right-width: 0 !important;\r\n\t\toverflow: hidden;\r\n\t}\r\n\r\n\t.ec-sidebar--collapsed-desktop .ec-sidebar__panel {\r\n\t\ttransform: translateX(-100%);\r\n\t}\r\n}\r\n\r\n.ec-sidebar__brand {\r\n\tdisplay: flex;\r\n\talign-items: center;\r\n\tgap: 10px;\r\n\tpadding: 14px 16px;\r\n\tmin-height: 56px;\r\n\tmin-width: 0;\r\n\twidth: 100%;\r\n\tmax-width: 100%;\r\n\tborder-bottom: 1px solid var(--ec-sidebar-border, #e5e5e5);\r\n\tflex-shrink: 0;\r\n\t/* Strike 2: dropped `contain: paint` here — it was establishing a paint\r\n\t   containment context that clipped the context switcher popover (which is\r\n\t   a child of `.ec-ws` inside this slot). Hover-bleed is now prevented at\r\n\t   the button level (overflow hidden on the trigger itself) while the\r\n\t   popover floats free via absolute positioning + high z-index. */\r\n\tbox-sizing: border-box;\r\n}\r\n\r\nhtml.dark .ec-sidebar__brand {\r\n\tborder-bottom-color: rgba(255, 255, 255, 0.1);\r\n}\r\n\r\n/* ---------------------------------------------------------------------------\r\n   Workspace Context Switcher — box model lockdown.\r\n   Constrains the trigger/button to the sidebar rail so hover backgrounds and\r\n   focus rings never paint past it, while leaving the popover free to float\r\n   over the main canvas (the popover is absolutely positioned with its own\r\n   z-index and is NOT subject to `contain: paint`).\r\n   --------------------------------------------------------------------------- */\r\n.ec-sidebar__brand--switcher,\r\n.ec-sidebar__brand--switcher *::before,\r\n.ec-sidebar__brand--switcher *::after {\r\n\tbox-sizing: border-box;\r\n\tmax-width: 100%;\r\n\tmargin-left: 0;\r\n\tmargin-right: 0;\r\n}\r\n\r\n/* Keep the trigger exactly rail-wide. Do NOT apply `contain: paint` here —\r\n   that would clip the absolutely-positioned popover when it opens. */\r\n.ec-sidebar__brand--switcher .ec-ws,\r\n.ec-sidebar__brand--switcher .ec-ws__trigger {\r\n\twidth: 100%;\r\n\tmax-width: 100%;\r\n\tmin-width: 0;\r\n\tmargin: 0;\r\n\tbox-sizing: border-box;\r\n}\r\n\r\n.ec-sidebar__brand--switcher .ec-ws__trigger:hover,\r\n.ec-sidebar__brand--switcher .ec-ws__trigger:focus,\r\n.ec-sidebar__brand--switcher .ec-ws__trigger:focus-visible,\r\n.ec-sidebar__brand--switcher .ec-ws__trigger:active {\r\n\tmargin: 0;\r\n\tmax-width: 100%;\r\n\toutline: none;\r\n\tbox-shadow: none;\r\n}\r\n\r\n/* Focus-visible ring is drawn inside the button so it never clips across the\r\n   sidebar border onto the main canvas. */\r\n.ec-sidebar__brand--switcher .ec-ws__trigger:focus-visible {\r\n\tbox-shadow: inset 0 0 0 2px var(--focus-ring-color, rgba(99, 102, 241, 0.35));\r\n}\r\n\r\n.ec-sidebar__title {\r\n\tfont-size: 13px;\r\n\tfont-weight: 600;\r\n\tletter-spacing: -0.02em;\r\n\tcolor: var(--text-primary);\r\n\tmargin: 0;\r\n\tline-height: 1.2;\r\n}\r\n\r\n.ec-sidebar__subtitle {\r\n\tfont-size: 11px;\r\n\tfont-weight: 500;\r\n\tcolor: var(--text-secondary);\r\n\tmargin: 2px 0 0;\r\n}\r\n\r\n.ec-sidebar__nav {\r\n\tflex: 1;\r\n\tmin-height: 0;\r\n\tmin-width: 0;\r\n\toverflow-x: hidden;\r\n\toverflow-y: auto;\r\n\tpadding: 8px 10px 16px;\r\n\tdisplay: flex;\r\n\tflex-direction: column;\r\n\tgap: 2px;\r\n}\r\n\r\n.ec-sidebar__system {\r\n\tflex-shrink: 0;\r\n\tmargin-top: auto;\r\n\tpadding: 8px 10px 12px;\r\n\tborder-top: 1px solid #e4e4e7;\r\n}\r\n\r\nhtml.dark .ec-sidebar__system {\r\n\tborder-top-color: rgba(255, 255, 255, 0.1);\r\n}\r\n\r\n.ec-sidebar__system-label {\r\n\tmargin: 0 0 6px;\r\n\tpadding: 0 10px;\r\n\tfont-size: 10px;\r\n\tfont-weight: 700;\r\n\ttext-transform: uppercase;\r\n\tletter-spacing: 0.06em;\r\n\tcolor: var(--text-secondary);\r\n}\r\n\r\n.ec-nav-link {\r\n\tdisplay: flex;\r\n\talign-items: center;\r\n\tgap: 8px;\r\n\tpadding: 8px 10px;\r\n\tborder-radius: 6px;\r\n\tfont-size: 13px;\r\n\tfont-weight: 500;\r\n\tcolor: var(--text-secondary);\r\n\ttext-decoration: none;\r\n\tborder: none;\r\n\tbackground: transparent;\r\n\twidth: 100%;\r\n\tmin-width: 0;\r\n\ttext-align: left;\r\n\tcursor: pointer;\r\n\ttransition: background var(--motion-fast) var(--motion-ease), color var(--motion-fast) var(--motion-ease), transform 150ms ease;\r\n\tletter-spacing: -0.01em;\r\n}\r\n\r\n.ec-nav-link:active {\r\n\ttransform: scale(0.95);\r\n}\r\n\r\n@media (prefers-reduced-motion: reduce) {\r\n\t.ec-nav-link:active {\r\n\t\tt