const __vite__css = "/**\r\n * Nexus Command OS — Global Enterprise SIEM Stylesheet\r\n * ──────────────────────────────────────────────────────\r\n * Phase 0: Slate-900 dark-mode-first aesthetic (Vanguard Protocol).\r\n *\r\n * Typography:\r\n *   Headings + UI labels  → Geist Sans   (Google Fonts CDN via app.html)\r\n *   Data / metrics / mono → Geist Mono   (@fontsource/geist-mono, loaded in +layout.svelte)\r\n *\r\n * Tailwind layer order:\r\n *   @tailwind base       → CSS variable injection (preflight disabled in tailwind.config.js)\r\n *   @tailwind components → .vanguard-card, .vanguard-btn-* component classes (line ~234)\r\n *   @tailwind utilities  → tw-* utility classes (line ~594)\r\n */\r\n\r\n*, ::before, ::after {\r\n\t--tw-border-spacing-x: 0;\r\n\t--tw-border-spacing-y: 0;\r\n\t--tw-translate-x: 0;\r\n\t--tw-translate-y: 0;\r\n\t--tw-rotate: 0;\r\n\t--tw-skew-x: 0;\r\n\t--tw-skew-y: 0;\r\n\t--tw-scale-x: 1;\r\n\t--tw-scale-y: 1;\r\n\t--tw-pan-x:  ;\r\n\t--tw-pan-y:  ;\r\n\t--tw-pinch-zoom:  ;\r\n\t--tw-scroll-snap-strictness: proximity;\r\n\t--tw-gradient-from-position:  ;\r\n\t--tw-gradient-via-position:  ;\r\n\t--tw-gradient-to-position:  ;\r\n\t--tw-ordinal:  ;\r\n\t--tw-slashed-zero:  ;\r\n\t--tw-numeric-figure:  ;\r\n\t--tw-numeric-spacing:  ;\r\n\t--tw-numeric-fraction:  ;\r\n\t--tw-ring-inset:  ;\r\n\t--tw-ring-offset-width: 0px;\r\n\t--tw-ring-offset-color: #fff;\r\n\t--tw-ring-color: rgb(59 130 246 / 0.5);\r\n\t--tw-ring-offset-shadow: 0 0 #0000;\r\n\t--tw-ring-shadow: 0 0 #0000;\r\n\t--tw-shadow: 0 0 #0000;\r\n\t--tw-shadow-colored: 0 0 #0000;\r\n\t--tw-blur:  ;\r\n\t--tw-brightness:  ;\r\n\t--tw-contrast:  ;\r\n\t--tw-grayscale:  ;\r\n\t--tw-hue-rotate:  ;\r\n\t--tw-invert:  ;\r\n\t--tw-saturate:  ;\r\n\t--tw-sepia:  ;\r\n\t--tw-drop-shadow:  ;\r\n\t--tw-backdrop-blur:  ;\r\n\t--tw-backdrop-brightness:  ;\r\n\t--tw-backdrop-contrast:  ;\r\n\t--tw-backdrop-grayscale:  ;\r\n\t--tw-backdrop-hue-rotate:  ;\r\n\t--tw-backdrop-invert:  ;\r\n\t--tw-backdrop-opacity:  ;\r\n\t--tw-backdrop-saturate:  ;\r\n\t--tw-backdrop-sepia:  ;\r\n\t--tw-contain-size:  ;\r\n\t--tw-contain-layout:  ;\r\n\t--tw-contain-paint:  ;\r\n\t--tw-contain-style:  ;\r\n}\r\n\r\n::backdrop {\r\n\t--tw-border-spacing-x: 0;\r\n\t--tw-border-spacing-y: 0;\r\n\t--tw-translate-x: 0;\r\n\t--tw-translate-y: 0;\r\n\t--tw-rotate: 0;\r\n\t--tw-skew-x: 0;\r\n\t--tw-skew-y: 0;\r\n\t--tw-scale-x: 1;\r\n\t--tw-scale-y: 1;\r\n\t--tw-pan-x:  ;\r\n\t--tw-pan-y:  ;\r\n\t--tw-pinch-zoom:  ;\r\n\t--tw-scroll-snap-strictness: proximity;\r\n\t--tw-gradient-from-position:  ;\r\n\t--tw-gradient-via-position:  ;\r\n\t--tw-gradient-to-position:  ;\r\n\t--tw-ordinal:  ;\r\n\t--tw-slashed-zero:  ;\r\n\t--tw-numeric-figure:  ;\r\n\t--tw-numeric-spacing:  ;\r\n\t--tw-numeric-fraction:  ;\r\n\t--tw-ring-inset:  ;\r\n\t--tw-ring-offset-width: 0px;\r\n\t--tw-ring-offset-color: #fff;\r\n\t--tw-ring-color: rgb(59 130 246 / 0.5);\r\n\t--tw-ring-offset-shadow: 0 0 #0000;\r\n\t--tw-ring-shadow: 0 0 #0000;\r\n\t--tw-shadow: 0 0 #0000;\r\n\t--tw-shadow-colored: 0 0 #0000;\r\n\t--tw-blur:  ;\r\n\t--tw-brightness:  ;\r\n\t--tw-contrast:  ;\r\n\t--tw-grayscale:  ;\r\n\t--tw-hue-rotate:  ;\r\n\t--tw-invert:  ;\r\n\t--tw-saturate:  ;\r\n\t--tw-sepia:  ;\r\n\t--tw-drop-shadow:  ;\r\n\t--tw-backdrop-blur:  ;\r\n\t--tw-backdrop-brightness:  ;\r\n\t--tw-backdrop-contrast:  ;\r\n\t--tw-backdrop-grayscale:  ;\r\n\t--tw-backdrop-hue-rotate:  ;\r\n\t--tw-backdrop-invert:  ;\r\n\t--tw-backdrop-opacity:  ;\r\n\t--tw-backdrop-saturate:  ;\r\n\t--tw-backdrop-sepia:  ;\r\n\t--tw-contain-size:  ;\r\n\t--tw-contain-layout:  ;\r\n\t--tw-contain-paint:  ;\r\n\t--tw-contain-style:  ;\r\n}\r\n\r\n/* ── Self-hosted JetBrains Mono (latin subset, woff2 — variable font) ──── */\r\n@font-face {\r\n\tfont-family: 'JetBrains Mono';\r\n\tfont-style: normal;\r\n\tfont-weight: 100 900;\r\n\tfont-display: swap;\r\n\tsrc: url('/fonts/jetbrains-mono-latin-700.woff2') format('woff2');\r\n\tunicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA,\r\n\t\tU+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193,\r\n\t\tU+2212, U+2215, U+FEFF, U+FFFD;\r\n}\r\n\r\nhtml {\r\n\toverflow-y: scroll !important;\r\n}\r\n\r\n/* ── Custom Vanguard scrollbar — WebKit / Blink ───────────────────────── */\r\n::-webkit-scrollbar {\r\n\twidth: 4px;\r\n\theight: 4px;\r\n}\r\n\r\n::-webkit-scrollbar-track {\r\n\tbackground: var(--vanguard-bg);\r\n}\r\n\r\n::-webkit-scrollbar-thumb {\r\n\tbackground: rgba(148, 163, 184, 0.25);\r\n\tborder-radius: 2px;\r\n}\r\n\r\n::-webkit-scrollbar-thumb:hover {\r\n\tbackground: rgba(148, 163, 184, 0.45);\r\n}\r\n\r\n::-webkit-scrollbar-corner {\r\n\tbackground: var(--vanguard-bg);\r\n}\r\n\r\n/* Firefox thin scrollbar with matching colours */\r\n* {\r\n\tscrollbar-width: thin;\r\n\tscrollbar-color: rgba(148, 163, 184, 0.25) var(--vanguard-bg);\r\n}\r\n\r\n/**\r\n * Nexus Command OS — global enterprise SIEM shell tokens.\r\n * Enterprise Slate / Indigo palette — tactical HUD chrome.\r\n *\r\n * DESIGN TOKEN DICTIONARY\r\n * ────────────────────────\r\n * --vanguard-bg      Enterprise Slate-900 global background (#0f172a)\r\n * --vanguard-cyan    Primary Indigo Accent / Success / XP (#6366f1)\r\n * --vanguard-red     Critical / Danger / Errors\r\n * --vanguard-glass   Glassmorphism base surface (slate-tinted)\r\n * --vanguard-border  Subtle indigo border\r\n *\r\n * Tailwind aliases: tw-bg-vanguard-bg, tw-text-vanguard-cyan,\r\n *   tw-border-vanguard-border, tw-shadow-vanguard-card, etc.\r\n */\r\n:root {\r\n\t/* ── Nexus Command Token Dictionary (canonical) ──────────────────── */\r\n\t--vanguard-bg:        #0f172a;   /* Slate-900 global background — NO pure black */\r\n\r\n\t/* ── Opaque surface tokens — data cards MUST use these, not glass ── */\r\n\t--vanguard-surface:        #131c2e;  /* Primary card / panel fill */\r\n\t--vanguard-surface-raised: #182236;  /* Elevated rows, table headers */\r\n\r\n\t/* ── Muted slate-teal accent (replaces Tron neon #14b8a6 / #6366f1) */\r\n\t--vanguard-accent:     #14b8a6;\r\n\t--vanguard-accent-dim: rgba(20, 184, 166, 0.45);\r\n\r\n\t/* ── DEPRECATED aliases — alias to accent; remove after full migration */\r\n\t--vanguard-cyan:  #14b8a6;  /* was: #6366f1 */\r\n\r\n\t--vanguard-red:       #ff003c;\r\n\t--vanguard-glass:     rgba(19, 28, 46, 0.72);  /* Floating modals / dock only */\r\n\t--vanguard-border:    rgba(148, 163, 184, 0.12); /* Slate-400 @ 12% — thin, NOT teal */\r\n\t--vanguard-border-strong: rgba(148, 163, 184, 0.22);\r\n\t--border-slate-800:   #1e293b;          /* Sprint 9.3: 1px opaque border for all non-modal cards */\r\n\t--surface-modal-scrim: rgba(0, 0, 0, 0.75); /* Sprint 9.3: ONLY legitimate modal backdrop use */\r\n\t--vanguard-text-primary:   #e2e8f0; /* Slate-200 */\r\n\t--vanguard-text-secondary: #94a3b8; /* Slate-400 */\r\n\t--vanguard-radius:    1.5rem;   /* 24px — primary card/panel radius */\r\n\t--vanguard-radius-sm: 0.75rem;  /* 12px — button/badge radius */\r\n\t--vanguard-radius-md: 1rem;     /* 16px — modal / sub-panel */\r\n\t--vanguard-radius-xs: 0.5rem;   /* 8px  — chip / tag (last resort) */\r\n\r\n\t/* ── Vanguard Blur Scale — floating surfaces only ───────────────── */\r\n\t--vanguard-blur-sm: 16px;\r\n\t--vanguard-blur:    24px;\r\n\t--vanguard-blur-lg: 40px;\r\n\r\n\t/* ── Motion Scale — 150-250ms canonical range ────────────────────── */\r\n\t--motion-fast: 150ms;  /* State toggles, hover background fills */\r\n\t--motion-base: 200ms;  /* Primary buttons, card hovers, focus ring */\r\n\t--motion-slow: 250ms;  /* Drawer/modal open, page transitions */\r\n\t--motion-ease: cubic-bezier(0.2, 0.8, 0.2, 1);  /* Premium snap, no bounce */\r\n\r\n\t/* ── Typography tokens ───────────────────────────────────────────── */\r\n\t--font-sans: 'Geist', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;\r\n\t--font-body: var(--font-sans);\r\n\t--font-display: var(--font-sans);\r\n\t--font-mono: 'Geist Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;\r\n\r\n\t/* ── Vanguard Elevation Scale — NO neon halos on data cards ─────── */\r\n\t/* elev-1: chips / inputs — minimal rim + soft drop */\r\n\t--vanguard-elev-1:\r\n\t\tinset 0 1px 0 rgba(255, 255, 255, 0.04),\r\n\t\t0 1px 2px rgba(0, 0, 0, 0.4);\r\n\t/* elev-2: cards / panels — inset rim + ambient depth (no cyan halo) */\r\n\t--vanguard-elev-2:\r\n\t\tinset 0 1px 0 rgba(255, 255, 255, 0.05),\r\n\t\t0 4px 12px -4px rgba(0, 0, 0, 0.55);\r\n\t/* elev-3: floating modals/heroes/drawers — stronger depth (glass layers only) */\r\n\t--vanguard-elev-3:\r\n\t\tinset 0 1px 0 rgba(255, 255, 255, 0.06),\r\n\t\t0 12px 32px -10px rgba(0, 0, 0, 0.65);\r\n\t/* elev-ares: breach / critical state — crimson inset + red glow (state, not decoration) */\r\n\t--vanguard-elev-ares:\r\n\t\tinset 0 0 0 1px rgba(255, 0, 60, 0.3),\r\n\t\t0 0 24px rgba(255, 0, 60, 0.35),\r\n\t\t0 16px 40px -12px rgba(0, 0, 0, 0.6);\r\n\r\n\t/* ── Marketing Legibility Tier ──────────────────────────────────── */\r\n\t/* Glass surface dark enough to guarantee ≥AA contrast on white text */\r\n\t--vanguard-glass-legible:   rgba(7, 12, 26, 0.82);\r\n\t--vanguard-border-legible:  rgba(99, 102, 241, 0.45);\r\n\t/* Semantic text tokens — contrast ratios on --vanguard-glass-legible:\r\n\t   text-1 (#fff)     = 18.1:1   (AAA)\r\n\t   text-2 (#e2e8f0)  = 14.7:1   (AAA)\r\n\t   text-3 (#cbd5e1)  = 11.5:1   (AAA)\r\n\t   text-eyebrow (#a5b4fc) = 8.4:1 (AAA) */\r\n\t--vanguard-text-1:          #ffffff;\r\n\t--vanguard-text-2:          #e2e8f0;\r\n\t--vanguard-text-3:          #cbd5e1;\r\n\t--vanguard-text-eyebrow:    #a5b4fc;\r\n\t/* Minimum font-size floor for marketing copy */\r\n\t--vanguard-text-min:        0.875rem;   /* 14px */\r\n\t--vanguard-text-eyebrow-size: 0.6875rem; /* 11px */\r\n\r\n\t/* ── Bento Grid Spacing Tokens ──────────────────────────────────── */\r\n\t--bento-gap-xs:  clamp(0.5rem,  1.5vw, 0.75rem);\r\n\t--bento-gap-sm:  clamp(0.75rem, 2vw,   1rem);\r\n\t--bento-gap-md:  clamp(1rem,    2.8vw, 1.5rem);\r\n\t--bento-gap-lg:  clamp(1.5rem,  3.5vw, 2.5rem);\r\n\t--bento-pad:     clamp(1rem,    3vw,   1.75rem);\r\n\t--bento-pad-sm:  clamp(0.75rem, 2vw,   1.25rem);\r\n\r\n\t/* ── Sprint 1.1 Liquid Bento Tokens ─────────────────────────────── */\r\n\t/* Exact ROADMAP spec: clamp(20px, 4vw, 32px) */\r\n\t--bento-gap-liquid: clamp(20px, 4vw, 32px);\r\n\t--bento-pad-liquid: clamp(20px, 4vw, 32px);\r\n\t/*\r\n\t * --shadow-liquid: tactile \"Liquid Glass\" elevation stack.\r\n\t *   Layer 1 (inset): 1px inner top-highlight — simulates glass refraction.\r\n\t *   Layer 2 (inset): subtle bottom-rim to close the shape.\r\n\t *   Layer 3 (drop):  soft ambient depth — premium tactile feel.\r\n\t *   Layer 4 (drop):  tight crisp drop for z-separation.\r\n\t * Applied ONLY to .vanguard-surface--liquid (opaque cards).\r\n\t * .vanguard-surface--hero-liquid uses this + backdrop-filter (glass carve-out allowed).\r\n\t */\r\n\t--shadow-liquid:\r\n\t\tinset 0 1px 0 rgba(255, 255, 255, 0.08),\r\n\t\tinset 0 -1px 0 rgba(0, 0, 0, 0.18),\r\n\t\t0 8px 32px -8px rgba(0, 0, 0, 0.55),\r\n\t\t0 2px 6px -2px rgba(0, 0, 0, 0.35);\r\n\r\n\t/* ── 60-30-10 enterprise palette (white-label via director branding) ─ */\r\n\t--color-dominant: var(--brand-dominant, #0f172a);\r\n\t--color-structural: var(--brand-structural, #3b82f6);\r\n\t--color-accent: var(--brand-accent, #fbbf24);\r\n\r\n\t/* ── ENTERPRISE SLATE (Backgrounds) ─────────────────────────────── */\r\n\t--void-black: #000000;\r\n\t--obsidian: #0f172a;\r\n\r\n\t/* ── NEXUS: STANDARD OPS ─────────────────────────────────────────── */\r\n\t--legacy-cyan: #14b8a6;  /* DEPRECATED alias → --vanguard-accent */\r\n\t--legacy-glow: none;     /* was: neon cyan halo — zeroed; var() calls degrade gracefully */\r\n\t--legacy-glass: rgba(19, 28, 46, 0.72);\r\n\r\n\t/* ── TRON: ARES (Threat State & Overrides) ───────────────────────── */\r\n\t--ares-crimson: #ff0033;\r\n\t--ares-glow: 0 0 25px rgba(255, 0, 51, 0.6), inset 0 0 15px rgba(255, 0, 51, 0.3);\r\n\t--ares-glass: rgba(20, 0, 0, 0.9);\r\n\r\n\t/* ── AAA HUD GREEBLING ───────────────────────────────────────────── */\r\n\t--ui-border-thin: 1px solid rgba(255, 255, 255, 0.08);\r\n\r\n\t--vanguard-z-base: 0;\r\n\t--vanguard-z-dock: 50;\r\n\t--vanguard-z-overlay: 9999;\r\n\t/** Coach workspace header subtract height — matches `--spacing-header` / `theme(spacing.header)` */\r\n\t--vanguard-shell-header: 5rem;\r\n}\r\n\r\n/**\r\n * The Arena — global grid readout.\r\n * Background: vanguard-bg with a faint cyan grid overlay for the SIEM aesthetic.\r\n */\r\nbody {\r\n\tmargin: 0;\r\n\tbackground-color: var(--vanguard-bg);\r\n\tbackground-image:\r\n\t\tlinear-gradient(to right, rgba(148, 163, 184, 0.03) 1px, transparent 1px),\r\n\t\tlinear-gradient(to bottom, rgba(148, 163, 184, 0.03) 1px, transparent 1px);\r\n\tbackground-size: 4rem 4rem;\r\n\tbackground-attachment: fixed;\r\n\tcolor: var(--vanguard-text-primary); /* slate-200 — high contrast on enterprise slate */\r\n\tfont-family: var(--font-body);\r\n}\r\n\r\n/**\r\n * MOBILE HARDENING — WCAG 2.5.5 / Apple HIG 44×44px touch target baseline.\r\n * Ensures every interactive element is tappable on small screens.\r\n * Uses min-height/min-width only — does not change visual size.\r\n */\r\n@media (pointer: coarse) {\r\n\tbutton,\r\n\t[role='button'],\r\n\ta,\r\n\tinput[type='checkbox'],\r\n\tinput[type='radio'],\r\n\tinput[type='range'],\r\n\tselect,\r\n\tlabel[for] {\r\n\t\tmin-height: 44px;\r\n\t}\r\n\r\n\t/* Inline / icon buttons that render smaller — pad with ::after pseudo-target */\r\n\t.touch-target-sm {\r\n\t\tposition: relative;\r\n\t}\r\n\t.touch-target-sm::after {\r\n\t\tcontent: '';\r\n\t\tposition: absolute;\r\n\t\tinset: -10px;\r\n\t}\r\n}\r\n\r\n/**\r\n * SAFE-AREA insets — iPhone notch + Dynamic Island support.\r\n * Prevents content from being clipped under the notch / home bar.\r\n */\r\n.safe-area-pb { padding-bottom: env(safe-area-inset-bottom, 0px); }\r\n.safe-area-pt { padding-top: env(safe-area-inset-top, 0px); }\r\n.safe-area-pl { padding-left: env(safe-area-inset-left, 0px); }\r\n.safe-area-pr { padding-right: env(safe-area-inset-right, 0px); }\r\n\r\n/*\r\n\t * ╔══════════════════════════════════════════════════════════════════╗\r\n\t * ║  GLASSMORPHISM CARVE-OUT — ALLOWED SURFACES (per .cursorrules)  ║\r\n\t * ║  backdrop-filter is ONLY permitted on:                          ║\r\n\t * ║  • .vanguard-surface--hero        (floating modals / heroes)    ║\r\n\t * ║  • .vanguard-surface--hero-liquid (Sprint 1.1 Bento hero tile)  ║\r\n\t * ║  • .tw-vanguard-dock-pill         (floating dock chrome)        ║\r\n\t * ║  • CommandPalette.svelte          (sticky search overlay)       ║\r\n\t * ║  • .vanguard-surface--modal       (sticky headers / dropdowns)  ║\r\n\t * ║  ALL data cards use opaque var(--vanguard-surface) fills.       ║\r\n\t * ║  .vanguard-surface--liquid is opaque — NO backdrop-filter.      ║\r\n\t * ╚══════════════════════════════════════════════════════════════════╝\r\n\t */\r\n\r\n/**\r\n\t * .vanguard-surface\r\n\t * Canonical opaque data-card surface. All card/panel primitives compose on this.\r\n\t * Use modifiers to vary elevation, radius, or enable glass for floating layers.\r\n\t */\r\n\r\n.vanguard-surface {\r\n\t\tbackground: var(--vanguard-surface);\r\n\t\tborder: 1px solid var(--vanguard-border);\r\n\t\tborder-radius: var(--vanguard-radius);\r\n\t\tbox-shadow: var(--vanguard-elev-2);\r\n\t}\r\n\r\n/* chips / inputs — minimal rim + soft drop */\r\n\r\n/* modal / sub-panel — 16px radius, same elevation as base */\r\n\r\n/* FLOATING GLASS — hero overlays / modals / drawers only */\r\n\r\n/* FLOATING GLASS — sticky modal variant */\r\n\r\n/* breach / critical threat state — crimson rim + red glow */\r\n\r\n/* floating dock pill — pill shape + elev-1 */\r\n\r\n/* flat / performance override — no backdrop blur */\r\n\r\n/**\r\n\t * .vanguard-surface--legible\r\n\t * Marketing-copy-safe glass tier. Darker base ensures ≥AA contrast even\r\n\t * when a busy grid pattern scrolls beneath the panel.\r\n\t * Apply to any marketing section that renders paragraph-level copy.\r\n\t */\r\n\r\n.vanguard-surface--legible :where(.eyebrow) {\r\n\t\tcolor: var(--vanguard-text-eyebrow);\r\n\t\tfont-size: var(--vanguard-text-eyebrow-size);\r\n\t}\r\n\r\n/**\r\n\t * .vanguard-card\r\n\t * Opaque data-card surface. Solid fill ensures text contrast on SIEM dashboards.\r\n\t * Do NOT add backdrop-filter here — glass is reserved for floating overlays only.\r\n\t */\r\n\r\n.vanguard-card {\r\n\t\tbackground: var(--vanguard-surface);\r\n\t\tborder: 1px solid var(--vanguard-border);\r\n\t\tborder-radius: var(--vanguard-radius);\r\n\t\tbox-shadow: var(--vanguard-elev-2);\r\n\t}\r\n\r\n/**\r\n\t * .vanguard-btn-primary\r\n\t * Teal-accent CTA. Idle: translucent tint + teal border.\r\n\t * Hover: subtle fill lift only — no neon halo.\r\n\t */\r\n\r\n.vanguard-btn-primary {\r\n\t\tdisplay: inline-flex;\r\n\t\talign-items: center;\r\n\t\tjustify-content: center;\r\n\t\tgap: 0.5rem;\r\n\t\twidth: -moz-fit-content;\r\n\t\twidth: fit-content;\r\n\t\tmin-height: 44px;\r\n\t\tbackground: rgba(20, 184, 166, 0.08);\r\n\t\tborder: 1px solid var(--vanguard-accent);\r\n\t\tcolor: var(--vanguard-accent);\r\n\t\tfont-family: var(--font-mono);\r\n\t\tfont-size: 0.75rem;\r\n\t\tletter-spacing: 0.08em;\r\n\t\ttext-transform: uppercase;\r\n\t\tpadding: 0.5rem 1rem;\r\n\t\tborder-radius: var(--vanguard-radius-sm);\r\n\t\tcursor: pointer;\r\n\t\ttransition:\r\n\t\t\tbackground var(--motion-base) var(--motion-ease),\r\n\t\t\tborder-color var(--motion-base) var(--motion-ease);\r\n\t}\r\n\r\n.vanguard-btn-primary:hover:not(:disabled) {\r\n\t\tbackground: rgba(20, 184, 166, 0.16);\r\n\t\tborder-color: var(--vanguard-accent);\r\n\t}\r\n\r\n.vanguard-btn-primary:disabled {\r\n\t\topacity: 0.4;\r\n\t\tcursor: not-allowed;\r\n\t}\r\n\r\n/**\r\n\t * .vanguard-btn-danger\r\n\t * Ares Red CTA — for destructive / critical actions.\r\n\t * Hover glow is intentionally retained as a critical-state signal.\r\n\t */\r\n\r\n.vanguard-btn-danger {\r\n\t\tbackground: rgba(255, 0, 60, 0.08);\r\n\t\tborder: 1px solid var(--vanguard-red);\r\n\t\tcolor: var(--vanguard-red);\r\n\t\tfont-family: var(--font-mono);\r\n\t\tfont-size: 0.75rem;\r\n\t\tletter-spacing: 0.08em;\r\n\t\ttext-transform: uppercase;\r\n\t\tpadding: 0.5rem 1rem;\r\n\t\tborder-radius: var(--vanguard-radius-sm);\r\n\t\tcursor: pointer;\r\n\t\ttransition:\r\n\t\t\tbackground var(--motion-base) var(--motion-ease),\r\n\t\t\tbox-shadow var(--motion-base) var(--motion-ease);\r\n\t}\r\n\r\n.vanguard-btn-danger:hover:not(:disabled) {\r\n\t\tbackground: rgba(255, 0, 60, 0.18);\r\n\t\tbox-shadow: 0 0 12px rgba(255, 0, 60, 0.35);\r\n\t}\r\n\r\n.vanguard-btn-danger:disabled {\r\n\t\topacity: 0.4;\r\n\t\tcursor: not-allowed;\r\n\t}\r\n\r\n/* ── Bento Grid Primitives ───────────────────────────────────────── */\r\n\r\n/**\r\n\t * .bento-grid\r\n\t * Single-column base grid using fluid gap tokens.\r\n\t * Compose with modifier classes for multi-column breakpoints.\r\n\t * Controls layout only — never overrides visual chrome (glass, radius, shadow).\r\n\t */\r\n\r\n.bento-grid {\r\n\t\tdisplay: grid;\r\n\t\tgrid-template-columns: 1fr;\r\n\t\tgap: var(--bento-gap-md);\r\n\t\twidth: 100%;\r\n\t\tbox-sizing: border-box;\r\n\t}\r\n\r\n/* Flex/grid children default to min-width:auto; long content blows out bento cells */\r\n\r\n.bento-grid > * {\r\n\t\tmin-width: 0;\r\n\t}\r\n\r\n/** 2-col at 640px+ */\r\n\r\n.bento-grid.bento-grid--2col {\r\n\t\tgrid-template-columns: 1fr;\r\n\t}\r\n\r\n@media (min-width: 40rem) {\r\n\t\t.bento-grid.bento-grid--2col {\r\n\t\t\tgrid-template-columns: repeat(2, minmax(0, 1fr));\r\n\t\t}\r\n\t}\r\n\r\n/** 3-col at 1024px+ (2-col at 640px) */\r\n\r\n.bento-grid.bento-grid--3col {\r\n\t\tgrid-template-columns: 1fr;\r\n\t}\r\n\r\n@media (min-width: 40rem) {\r\n\t\t.bento-grid.bento-grid--3col {\r\n\t\t\tgrid-template-columns: repeat(2, minmax(0, 1fr));\r\n\t\t}\r\n\t}\r\n\r\n@media (min-width: 64rem) {\r\n\t\t.bento-grid.bento-grid--3col {\r\n\t\t\tgrid-template-columns: repeat(3, minmax(0, 1fr));\r\n\t\t}\r\n\t}\r\n\r\n/** 4-col at 1280px+ (2-col at 768px) */\r\n\r\n.bento-grid.bento-grid--4col {\r\n\t\tgrid-template-columns: 1fr;\r\n\t}\r\n\r\n@media (min-width: 48rem) {\r\n\t\t.bento-grid.bento-grid--4col {\r\n\t\t\tgrid-template-columns: repeat(2, minmax(0, 1fr));\r\n\t\t}\r\n\t}\r\n\r\n@media (min-width: 80rem) {\r\n\t\t.bento-grid.bento-grid--4col {\r\n\t\t\tgrid-template-columns: repeat(4, minmax(0, 1fr));\r\n\t\t}\r\n\t}\r\n\r\n/** 12-col asymmetric grid — Sprint 9.2 Player OS Bento\r\n\t *  Mobile: 1 col (all spans collapse to full width)\r\n\t *  Desktop (64rem+): 12 equal tracks for asymmetric card placement\r\n\t *  DO NOT add an intermediate 6-col breakpoint — radar+capsule row\r\n\t *  must remain stacked on tablet for readability.\r\n\t */\r\n\r\n.bento-grid.bento-grid--12col {\r\n\t\tgrid-template-columns: 1fr;\r\n\t}\r\n\r\n@media (min-width: 64rem) {\r\n\t\t.bento-grid.bento-grid--12col {\r\n\t\t\tgrid-template-columns: repeat(12, minmax(0, 1fr));\r\n\t\t}\r\n\t}\r\n\r\n/** Span helpers */\r\n\r\n/* Sprint 9.2 extended span helpers for 12-col asymmetric grid */\r\n\r\n.bento-span-3  { grid-column: span 3; }\r\n\r\n.bento-span-4  { grid-column: span 4; }\r\n\r\n.bento-span-5  { grid-column: span 5; }\r\n\r\n.bento-span-6  { grid-column: span 6; }\r\n\r\n.bento-span-8  { grid-column: span 8; }\r\n\r\n.bento-span-12 { grid-column: span 12; }\r\n\r\n/** Sprint 3.1.2 — collapse asymmetric spans on single-track mobile 12-col */\r\n\r\n@media (max-width: 63.99rem) {\r\n\t\t.bento-grid.bento-grid--12col > :where(\r\n\t\t\t.bento-span-2,\r\n\t\t\t.bento-span-3,\r\n\t\t\t.bento-span-4,\r\n\t\t\t.bento-span-5,\r\n\t\t\t.bento-span-6,\r\n\t\t\t.bento-span-8,\r\n\t\t\t.bento-span-9\r\n\t\t) {\r\n\t\t\tgrid-column: 1 / -1;\r\n\t\t}\r\n\t}\r\n\r\n/**\r\n\t * .bento-cell\r\n\t * Container query anchor + base padding for self-adjusting card content.\r\n\t * Apply to cards that need @container-based inner responsiveness.\r\n\t */\r\n\r\n.bento-cell {\r\n\t\tcontainer-type: inline-size;\r\n\t\tcontainer-name: bento;\r\n\t\tpadding: var(--bento-pad);\r\n\t\tbox-sizing: border-box;\r\n\t}\r\n\r\n/**\r\n\t * .bento-cell--interactive\r\n\t * Bento Grid 2.0 hover micro-interactions.\r\n\t * Composes on top of .vanguard-card — apply both classes.\r\n\t * GPU-only: transform + box-shadow + conic-gradient pseudo-element.\r\n\t * All animations are disabled under prefers-reduced-motion.\r\n\t */\r\n\r\n.bento-cell--interactive {\r\n\t\tposition: relative;\r\n\t\ttransition:\r\n\t\t\ttransform 220ms cubic-bezier(0.22, 0.61, 0.36, 1),\r\n\t\t\tborder-color 220ms ease,\r\n\t\t\tbox-shadow 260ms ease;\r\n\t\twill-change: transform;\r\n\t}\r\n\r\n.bento-cell--interactive:hover {\r\n\t\ttransform: translateY(-2px);\r\n\t\tborder-color: color-mix(in srgb, var(--vanguard-cyan) 55%, transparent);\r\n\t\tbox-shadow:\r\n\t\t\tvar(--vanguard-elev-3),\r\n\t\t\t0 0 28px color-mix(in srgb, var(--vanguard-cyan) 30%, transparent);\r\n\t}\r\n\r\n/* Conic-gradient border sweep — GPU composited, single pseudo-element */\r\n\r\n.bento-cell--interactive::before {\r\n\t\tcontent: '';\r\n\t\tposition: absolute;\r\n\t\tinset: -1px;\r\n\t\tborder-radius: inherit;\r\n\t\tpadding: 1px;\r\n\t\tbackground: conic-gradient(\r\n\t\t\tfrom var(--bento-angle, 0deg),\r\n\t\t\ttransparent 0 65%,\r\n\t\t\tcolor-mix(in srgb, var(--vanguard-cyan) 70%, transparent) 75%,\r\n\t\t\ttransparent 85%\r\n\t\t);\r\n\t\t-webkit-mask:\r\n\t\t\tlinear-gradient(#000 0 0) content-box,\r\n\t\t\tlinear-gradient(#000 0 0);\r\n\t\t-webkit-mask-composite: xor;\r\n\t\tmask-composite: exclude;\r\n\t\topacity: 0;\r\n\t\ttransition: opacity 220ms ease;\r\n\t\tpointer-events: none;\r\n\t}\r\n\r\n.bento-cell--interactive:hover::before {\r\n\t\topacity: 1;\r\n\t}\r\n\r\n.bento-cell--interactive:focus-visible {\r\n\t\toutline: 2px solid rgba(99, 102, 241, 0.65);\r\n\t\toutline-offset: 3px;\r\n\t}\r\n\r\n@media (prefers-reduced-motion: reduce) {\r\n\t\t.bento-cell--interactive,\r\n\t\t.bento-cell--interactive::before {\r\n\t\t\ttransition: none;\r\n\t\t\tanimation: none;\r\n\t\t}\r\n\t\t.bento-cell--interactive:hover {\r\n\t\t\ttransform: none;\r\n\t\t}\r\n\t}\r\n\r\n/* ── Sprint 1.1: Liquid Bento Grid modifier ──────────────────────── */\r\n\r\n/**\r\n\t * .bento-grid--liquid\r\n\t * Composes on top of .bento-grid--12col to add:\r\n\t *   • grid-auto-flow: dense — fills holes left by asymmetric spans\r\n\t *   • clamp(20px, 4vw, 32px) gap — ROADMAP-specified fluid spacing\r\n\t * Apply both classes: class=\"bento-grid bento-grid--12col bento-grid--liquid\"\r\n\t */\r\n\r\n.bento-grid--liquid {\r\n\t\tgrid-auto-flow: dense;\r\n\t\tgap: var(--bento-gap-liquid);\r\n\t}\r\n\r\n/**\r\n\t * Sprint 1.1 — fluid interior spacing inside bento cells.\r\n\t * Prefer these over tw-mb-4 / tw-gap-4 hardcoded scale inside bento wrappers.\r\n\t */\r\n\r\n.bento-mt-md { margin-top: var(--bento-gap-md); }\r\n\r\n.bento-mt-lg { margin-top: var(--bento-gap-lg); }\r\n\r\n.bento-mb-md { margin-bottom: var(--bento-gap-md); }\r\n\r\n.bento-mb-lg { margin-bottom: var(--bento-gap-lg); }\r\n\r\n.bento-gap-xs { gap: var(--bento-gap-xs); }\r\n\r\n.bento-gap-md { gap: var(--bento-gap-md); }\r\n\r\n.bento-gap-lg { gap: var(--bento-gap-lg); }\r\n\r\n.bento-stack-sm {\r\n\t\tdisplay: flex;\r\n\t\tflex-direction: column;\r\n\t\tgap: var(--bento-gap-sm);\r\n\t}\r\n\r\n.bento-stack-md {\r\n\t\tdisplay: flex;\r\n\t\tflex-direction: column;\r\n\t\tgap: var(--bento-gap-md);\r\n\t}\r\n\r\n/**\r\n\t * .vanguard-surface--liquid\r\n\t * Opaque data-card modifier for Sprint 1.1 Liquid Glass aesthetic.\r\n\t * Composes on .vanguard-card / .vanguard-surface — adds the tactile\r\n\t * --shadow-liquid elevation stack + a soft inner highlight.\r\n\t * MUST NOT use backdrop-filter — carve