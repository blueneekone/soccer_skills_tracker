# Cloud Functions deploy env template (copy to .env.sports-skill-tracker-dev or .env.soccer-skills-tracker).
# Do not commit real .env.* files — they are gitignored.

ADMIN_EMAIL=you@example.com
APP_BASE_URL=https://sstracker.app

# WebAuthn (compliance codebase) — required for passkeys on production hosting
WEBAUTHN_RP_ID=sstracker.app
WEBAUTHN_RP_ORIGIN=https://sstracker.app

TREMENDOUS_ENV=sandbox
FEATURE_SKILL_DECAY_ENABLED=TRUE
FEATURE_STREAK_ENFORCEMENT_ENABLED=TRUE
DECAY_GRACE_DAYS=5
DECAY_PCT_PER_DAY=2
DECAY_MAX_PCT=20
STREAK_FREEZE_PER_WEEK=2
